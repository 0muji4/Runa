# macOS
.DS_Store

# Go
/apps/go/bin/
*.exe
*.test
*.out

# Android / Kotlin / Gradle（apps/kotlin）
/apps/kotlin/.gradle/
/apps/kotlin/build/
/apps/kotlin/**/build/
/apps/kotlin/local.properties
/apps/kotlin/captures/
.kotlin/
*.iml
*.hprof
*.apk
*.aab
*.keystore
*.jks

# 環境・秘匿情報（DB 接続情報・API キー・鍵など）
.env
.env.*
!.env.example
*.local

# IDE / エディタ
.idea/
.vscode/

# Claude Code: 個人・マシン依存の設定は追跡しない。
# プロジェクト固有スキル（.claude/skills/）だけ追跡する。
.claude/*
!.claude/skills/

# iOS（apps/swift）— project.yml / Package.swift / ソースは追跡する。
# .xcodeproj は XcodeGen 生成物なので追跡しない（project.yml が正）。
apps/swift/**/xcuserdata/
apps/swift/DerivedData/
apps/swift/build/
apps/swift/*.xcodeproj
apps/swift/**/.DS_Store
