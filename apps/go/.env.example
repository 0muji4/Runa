# Runa backend configuration. Copy to .env for local overrides (.env is gitignored).

# TCP port the HTTP server listens on.
PORT=8080

# Postgres connection string (pgx/libpq format).
DATABASE_URL=postgres://runa:runa@localhost:5432/runa?sslmode=disable

# slog level: debug | info | warn | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. "*" allows any origin.
CORS_ALLOWED_ORIGINS=*

# Deployment environment: development | staging | production
APP_ENV=development

# --- Auth ---

# HS256 secret that signs access tokens. MUST be a long random value in any
# non-development environment (rotating it invalidates all live access tokens).
JWT_SECRET=dev-insecure-secret-change-me

# Access token lifetime (short) and refresh token lifetime (long). Go duration
# syntax: 15m, 1h, 720h (= 30 days).
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Comma-separated accepted audiences (client IDs) for provider ID tokens. Leave
# empty to disable that provider's verification. See README for how to obtain:
#   APPLE_CLIENT_IDS  — iOS app Bundle ID and/or the Apple Service ID
#   GOOGLE_CLIENT_IDS — the Google OAuth client IDs (iOS, Android, Web). The Web
#                       client ID is also what Android Credential Manager uses as
#                       serverClientId, so Android-issued tokens carry it as aud.
APPLE_CLIENT_IDS=com.runa
GOOGLE_CLIENT_IDS=890729556064-1965dtr47tk7qev9ie73fblkv14vanv7.apps.googleusercontent.com,890729556064-v8tfjso2kh0tuvuhaas2ub2o3olvft8k.apps.googleusercontent.com

# --- Today (curated content admin) ---

# Shared token guarding the /api/v1/admin/* seed endpoints (sent as X-Admin-Token).
# Leave EMPTY to disable the admin surface entirely (every admin request → 403).
# Set to a long random value to seed daily quotes/songs (see hack/seed-today.sh).
ADMIN_API_TOKEN=
