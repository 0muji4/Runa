# Runa backend configuration. Copy to .env for local overrides (.env is gitignored).

# TCP port the HTTP server listens on.
PORT=8080

# Postgres connection string (pgx/libpq format).
DATABASE_URL=postgres://runa:runa@localhost:5432/runa?sslmode=disable

# slog level: debug | info | warn | error
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. "*" allows any origin.
CORS_ALLOWED_ORIGINS=*

# Deployment environment: development | staging | production
APP_ENV=development
