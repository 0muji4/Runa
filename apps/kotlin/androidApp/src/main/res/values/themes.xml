<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimal Material3 dark theme so the manifest resolves and the launch
         window matches the app's dark background before Compose renders. The
         real design system lives in Compose (Theme.kt). -->
    <style name="Theme.Runa" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/runa_background</item>
        <item name="android:navigationBarColor">@color/runa_background</item>
        <item name="android:windowBackground">@color/runa_background</item>
        <item name="android:colorBackground">@color/runa_background</item>
    </style>
</resources>
