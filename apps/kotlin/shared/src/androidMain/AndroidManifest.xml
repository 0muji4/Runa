<?xml version="1.0" encoding="utf-8"?>
<!-- Shared-module manifest: the nightly-reminder notification infrastructure lives
     in shared androidMain (self-contained), and these entries merge into the app.
     POST_NOTIFICATIONS is requested at runtime in the app's onboarding (④). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application>
        <!-- Fired by the AlarmManager one-shot; not exported (only our PendingIntent
             triggers it). Posts the reminder and re-arms the next day. -->
        <receiver
            android:name="com.runa.shared.feature.notification.ReminderReceiver"
            android:exported="false" />

        <!-- Re-arms the schedule after a device reboot. -->
        <receiver
            android:name="com.runa.shared.feature.notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
