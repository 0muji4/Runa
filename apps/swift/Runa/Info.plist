<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>ja</string>
	<key>CFBundleDisplayName</key>
	<string>Runa</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Backend base URL injected into the app; shared appends /api/v1/healthz.
	     iOS simulator reaches the host machine via localhost. -->
	<key>BASE_URL</key>
	<string>http://localhost:8080</string>

	<!-- Google iOS OAuth client ID for Sign in with Google (empty = disabled).
	     Fill with the iOS client ID from Google Cloud, e.g.
	     123456789-abcdef.apps.googleusercontent.com. The backend must list this
	     client ID in GOOGLE_CLIENT_IDS. The web sign-in uses ASWebAuthenticationSession,
	     which intercepts the reversed-client-id callback without a URL scheme entry.
	     Sign in with Apple is native and needs no plist config (see Runa.entitlements). -->
	<key>GIDClientID</key>
	<string>890729556064-v8tfjso2kh0tuvuhaas2ub2o3olvft8k.apps.googleusercontent.com</string>

	<!-- Face ID usage: the privacy lock (22) authenticates with Face ID / Touch ID,
	     falling back to the device passcode. Required for LocalAuthentication. -->
	<key>NSFaceIDUsageDescription</key>
	<string>アプリのロック解除に Face ID を使用します。</string>

	<!-- Allow cleartext HTTP to the local dev backend over loopback/localhost.
	     Targeted exception — does NOT disable ATS globally. Mirrors Android's
	     android:usesCleartextTraffic for the dev backend. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- Appearance follows the in-app theme (dark/light/pink), applied by
	     ThemedRoot via preferredColorScheme. No app-wide UIUserInterfaceStyle lock. -->

	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- FONTS: the OFL binaries live under Runa/Fonts/ and are bundled by XcodeGen
	     (project.yml sources include the Runa folder). Family names registered here
	     must match the strings passed to Font.custom(...) in Theme/RunaFonts.swift.
	     See Runa/Fonts/README.md. -->
	<key>UIAppFonts</key>
	<array>
		<string>ShipporiMincho-Regular.ttf</string>
		<string>ShipporiMincho-Medium.ttf</string>
		<string>ZenKakuGothicNew-Regular.ttf</string>
		<string>ZenKakuGothicNew-Medium.ttf</string>
		<string>CormorantGaramond-Regular.ttf</string>
		<string>CormorantGaramond-Medium.ttf</string>
	</array>
</dict>
</plist>
